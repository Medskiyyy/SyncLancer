# PostgreSQL Connection URL (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres?schema=public"

# Auth.js v5 (NextAuth) Configuration
# Generate a secret via: openssl rand -base64 32
AUTH_SECRET="your-auth-secret-here"
AUTH_URL="http://localhost:3000"

# Google OAuth Credentials
AUTH_GOOGLE_ID="your-google-client-id"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# GitHub OAuth Credentials
AUTH_GITHUB_ID="your-github-client-id"
AUTH_GITHUB_SECRET="your-github-client-secret"

# Resend Email Service Key
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="SyncLancer <noreply@mail.synclancer.web.id>"

# Supabase Storage Credentials
NEXT_PUBLIC_SUPABASE_URL="https://your-supabase-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Vercel Cron Secret (Authorization for recurring invoices cron job)
CRON_SECRET="your-cron-secret-here"
